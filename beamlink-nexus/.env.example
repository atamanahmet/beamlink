# ── PostgreSQL ────────────────────────────────────────────────────
# DB_HOST and DB_PORT only needed if Postgres is not on localhost:5432
# DB_HOST=localhost
# DB_PORT=5432
DB_NAME=beamlink_db
DB_USERNAME=beamlink_admin
DB_PASSWORD=

# ── Nexus ─────────────────────────────────────────────────────────
NEXUS_NAME=Nexus
# Default port is 7472. Changing port is recommended.
NEXUS_PORT=7472
# Leave as "auto" to detect LAN IP automatically, or set a fixed IP.
NEXUS_IP=auto

# ── Admin ─────────────────────────────────────────────────────────
NEXUS_ADMIN_USERNAME=
NEXUS_ADMIN_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────
# Can leave as "auto". Secret, if not present, it is generated and saved here on first launch.
NEXUS_JWT_SECRET=auto

# ── Upload Limits ─────────────────────────────────────────────────
# -1 = unlimited. Set in MB, 100MB.
MULTIPART_MAX_FILE_SIZE=100MB
MULTIPART_MAX_REQUEST_SIZE=100MB
MULTIPART_FILE_SIZE_THRESHOLD=2MB
MULTIPART_ENABLED=true